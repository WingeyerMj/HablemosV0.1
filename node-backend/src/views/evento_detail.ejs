<!DOCTYPE html>
<html lang="es">

<%- include('partials/head') %>

    <body class="blog-details-page">

        <%- include('partials/header') %>

            <main class="main">

                <!-- Page Title -->
                <div class="page-title dark-background" data-aos="fade">
                    <div class="container d-lg-flex justify-content-between align-items-center">
                        <h1 class="mb-2 mb-lg-0"><%= evento.title %></h1>
                        <nav class="breadcrumbs">
                            <ol>
                                <li><a href="/">Inicio</a></li>
                                <li>Eventos</li>
                            </ol>
                        </nav>
                    </div>
                </div>

                <!-- Encabezado visible solo en el PDF -->
                <div id="pdf-header" style="display: none;">
                    <h1><%= evento.title %></h1>
                    <% if (evento.description) { %>
                        <p class="pdf-subtitle"><%= evento.description %></p>
                    <% } %>
                    <% if (evento.subtitle) { %>
                        <p class="pdf-subtitle"><i><%= evento.subtitle %></i></p>
                    <% } %>
                    <p class="pdf-subtitle" style="font-size: 10pt; color: #888;">Hablemos de YHWH &bull; www.hablemosdeyhwh.com</p>
                </div>

                <section id="blog-details" class="blog-details section">
                    <div class="container">

                        <article class="article">

                            <div class="row gy-4">
                                <div class="col-lg-8">
                                    <% if (evento.subtitle) { %>
                                        <div class="meta-top mb-4">
                                            <ul class="list-unstyled">
                                                <li class="d-flex align-items-center">
                                                    <i class="bi bi-calendar-event me-2"></i> 
                                                    <span class="badge bg-primary px-3 py-2 fs-6"><%= evento.subtitle %></span>
                                                </li>
                                            </ul>
                                        </div>
                                    <% } %>

                                    <div class="content mt-4" id="evento-content" style="font-size: 1.1rem; line-height: 1.8; color: #444;">
                                        <%- evento.content || evento.description %>
                                    </div>

                                    <!-- Botón Descargar PDF -->
                                    <div class="text-center mt-5 mb-4 no-print">
                                        <button onclick="descargarPDF()" class="btn btn-lg d-inline-flex align-items-center gap-2 shadow-sm" 
                                                style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 14px 35px; border-radius: 30px; font-weight: 600; transition: all 0.3s ease;">
                                            <i class="bi bi-file-earmark-pdf" style="font-size: 1.4rem;"></i>
                                            <span>Descargar Evento como PDF</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="col-lg-4">
                                    <% if (evento.image_url || evento.img) { %>
                                        <div class="post-img p-2" style="background: #fff; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); position: sticky; top: 100px;">
                                            <img src="<%= evento.image_url || evento.img %>" alt="<%= evento.title %>" class="img-fluid rounded" style="width: 100%; height: auto; object-fit: contain;">
                                        </div>
                                    <% } else { %>
                                        <div class="post-img p-4 text-center rounded" style="background: #f8f9fa; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); position: sticky; top: 100px;">
                                            <i class="bi bi-calendar-event text-muted" style="font-size: 5rem;"></i>
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                        </article>

                    </div>
                </section>

            </main>

            <%- include('partials/footer') %>

    <!-- Estilos para impresión / PDF -->
    <style>
        @media print {
            /* Ocultar elementos no necesarios en el PDF */
            .no-print,
            header, 
            nav, 
            footer, 
            .breadcrumbs,
            .page-title,
            .post-img,
            .scroll-top,
            #header,
            .footer {
                display: none !important;
            }

            body {
                background: white !important;
                color: #000 !important;
                font-size: 12pt !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            .main {
                padding: 0 !important;
                margin: 0 !important;
            }

            .blog-details.section {
                padding: 0 !important;
            }

            .container {
                max-width: 100% !important;
                padding: 0 20px !important;
            }

            /* Encabezado del PDF */
            #pdf-header {
                display: block !important;
                text-align: center;
                border-bottom: 2px solid #333;
                padding-bottom: 15px;
                margin-bottom: 25px;
            }

            #pdf-header h1 {
                font-size: 22pt !important;
                color: #000 !important;
                margin-bottom: 5px;
            }

            #pdf-header .pdf-subtitle {
                font-size: 12pt;
                color: #555;
            }

            /* Contenido */
            .content {
                font-size: 12pt !important;
                line-height: 1.6 !important;
                color: #000 !important;
            }

            .content img {
                max-width: 80% !important;
                margin: 10px auto;
                display: block;
            }

            .col-lg-8 {
                width: 100% !important;
                max-width: 100% !important;
                flex: 0 0 100% !important;
            }

            .col-lg-4 {
                display: none !important;
            }

            .badge {
                border: 1px solid #333 !important;
                background: white !important;
                color: #333 !important;
            }

            a {
                color: #000 !important;
                text-decoration: none !important;
            }
        }
    </style>

    <script>
        function descargarPDF() {
            window.print();
        }
    </script>

    </body>

</html>
