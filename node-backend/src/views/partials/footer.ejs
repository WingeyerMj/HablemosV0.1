<footer id="footer" class="footer dark-background">

    <div class="footer-newsletter">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-6">
                    <h4>Join Our Newsletter</h4>
                    <p>Subscribe to our newsletter and receive the latest news about our products and services!</p>
                    <form action="forms/newsletter.php" method="post" class="php-email-form">
                        <div class="newsletter-form"><input type="email" name="email"><input type="submit"
                                value="Subscribe"></div>
                        <div class="loading">Loading</div>
                        <div class="error-message"></div>
                        <div class="sent-message">Your subscription request has been sent. Thank you!</div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="container footer-top">
        <div class="row gy-4">
            <div class="col-lg-4 col-md-6 footer-about">
                <a href="/" class="d-flex align-items-center">
                    <img src="/assets/img/pagina/logo.svg" alt="YHWH Footer Logo"
                        style="max-height: 40px; border-radius: 50%; object-fit: cover; aspect-ratio: 1/1;">
                </a>
                <div class="footer-contact pt-3">
                    <h4 class="mb-2"><%= (typeof footerConfig !== 'undefined' && footerConfig && footerConfig.title) || 'Hablemos de YHWH' %></h4>
                    <p><%= (typeof footerConfig !== 'undefined' && footerConfig && footerConfig.subtitle) || '' %></p>
                    <p><%= (typeof footerConfig !== 'undefined' && footerConfig && footerConfig.content) || '' %></p>
                </div>
            </div>

            <% if (typeof footerLinks !== 'undefined' && footerLinks) { %>
                <% Object.keys(footerLinks).forEach(category => { %>
                    <div class="col-lg-2 col-md-3 footer-links">
                        <h4><%= category %></h4>
                        <ul>
                            <% footerLinks[category].forEach(link => { %>
                                <li><i class="bi bi-chevron-right"></i> <a href="<%= link.url %>"><%= link.title %></a></li>
                            <% }) %>
                        </ul>
                    </div>
                <% }) %>
            <% } %>

            <div class="col-lg-2 col-md-12">
                <h4>Síganos</h4>
                <div class="social-links d-flex">
                    <% const ssf = typeof siteSettings !== 'undefined' ? siteSettings : {}; %>
                    <% if (ssf.social_youtube) { %>
                        <a href="<%= ssf.social_youtube %>" target="_blank" rel="noopener noreferrer" title="YouTube"><i class="bi bi-youtube"></i></a>
                    <% } %>
                    <% if (ssf.social_facebook) { %>
                        <a href="<%= ssf.social_facebook %>" target="_blank" rel="noopener noreferrer" title="Facebook"><i class="bi bi-facebook"></i></a>
                    <% } %>
                    <% if (ssf.social_instagram) { %>
                        <a href="<%= ssf.social_instagram %>" target="_blank" rel="noopener noreferrer" title="Instagram"><i class="bi bi-instagram"></i></a>
                    <% } %>
                    <% if (ssf.social_whatsapp) { %>
                        <a href="<%= ssf.social_whatsapp %>" target="_blank" rel="noopener noreferrer" title="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                    <% } %>
                </div>
            </div>

        </div>
    </div>

    <div class="container copyright text-center mt-4">
        <p>© <span>Copyright</span> <strong class="px-1 sitename">Hablemos de YHWH</strong> <span>All Rights
                Reserved</span></p>
        <div class="credits">
            Designed by <a href="https://bootstrapmade.com/">BootstrapMade</a>
        </div>
    </div>

</footer>

<!-- Scroll Top -->
<a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i
        class="bi bi-arrow-up-short"></i></a>

<!-- Preloader -->
<div id="preloader"></div>

