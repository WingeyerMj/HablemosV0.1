<header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container-fluid position-relative d-flex align-items-center justify-content-between">
        
        <% if (typeof page !== 'undefined' && page !== 'home') { %>
            <a href="/" class="btn-back-header" title="Volver al Inicio" style="margin-right: 15px; font-size: 1.5rem; color: #d4b895; transition: transform 0.3s ease; display: flex; align-items: center;">
                <i class="bi bi-arrow-left-circle"></i>
            </a>
            <style>
                .btn-back-header:hover { transform: scale(1.1); color: #fff !important; }
            </style>
        <% } %>

        <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
            <img src="/assets/img/pagina/logo.svg" alt="YHWH Logo" class="logo-spin"
                style="border-radius: 50%; object-fit: cover; aspect-ratio: 1/1; max-height: 40px;">
            <h1 class="sitename ms-2 mb-0" style="font-size: 24px;">Hablemos de YHWH</h1>
        </a>

        <nav id="navmenu" class="navmenu">
            <ul>
                <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>"><i class="bi bi-house-door"></i>
                        Inicio</a></li>
                <li><a href="/calendar" class="<%= page === 'calendar' ? 'active' : '' %>"><i class="bi bi-calendar3"></i>
                        Calendario</a></li>
                <li><a href="/#services" class="<%= page === 'parashot' ? 'active' : '' %>"><i class="bi bi-journal-text"></i>
                        Parashot</a></li>

                <% if (typeof navbarDynamicSections !=='undefined' && navbarDynamicSections.length> 0) { %>
                    <% navbarDynamicSections.forEach(ds=> { %>
                        <% 
                            if (ds.slug === 'hero' || ds.slug === 'calendario') return; 
                            
                            let href = ds.section_type === 'inline' ? `/#section-${ds.slug}` : `/s/${ds.slug}`; 
                            
                            // Mapeo de slugs a secciones estáticas o rutas fijas
                            if (ds.slug === 'about') href = '/#about'; 
                            if (ds.slug === 'parashot') href = '/#services'; 
                            if (ds.slug === 'eventos') href = '/#portfolio'; 
                            if (ds.slug === 'equipo') href = '/#team'; 
                            if (ds.slug === 'calendario') href = '/calendar';
                            
                            const isActive = (typeof section !== 'undefined' && section && section.slug === ds.slug) || (ds.slug === 'calendario' && page === 'calendar');
                        %>
                        <li>
                            <a href="<%= href %>" class="<%= isActive ? 'active' : '' %>">
                                <i class="bi <%= ds.icon %>"></i>
                                <%= ds.title %>
                            </a>
                        </li>
                    <% }) %>
                <% } %>

                <li><a href="/blog" class="<%= page === 'blog' ? 'active' : '' %>"><i class="bi bi-newspaper"></i>
                        Blog</a></li>

                <li><a href="/#contact"><i class="bi bi-envelope"></i> Contacto</a></li>

                <% if (user) { %>
                    <li><a href="/admin/dashboard" class="btn-admin-access"
                            style="background: #d4b895; color: white; border-radius: 5px; padding: 5px 15px; margin-left: 10px;">Admin</a>
                    </li>
                <% } else { %>
                    <li><a href="/admin/login" class="btn-admin-access"
                            style="border: 1px solid #d4b895; border-radius: 5px; padding: 5px 15px; margin-left: 10px;">Ingresar</a>
                    </li>
                <% } %>
            </ul>
            <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

        <div class="header-social-links">
            <% const ss = typeof siteSettings !== 'undefined' ? siteSettings : {}; %>
            <% if (ss.social_youtube) { %>
                <a href="<%= ss.social_youtube %>" target="_blank" rel="noopener noreferrer" title="YouTube"><i class="bi bi-youtube"></i></a>
            <% } %>
            <% if (ss.social_facebook) { %>
                <a href="<%= ss.social_facebook %>" target="_blank" rel="noopener noreferrer" title="Facebook"><i class="bi bi-facebook"></i></a>
            <% } %>
            <% if (ss.social_instagram) { %>
                <a href="<%= ss.social_instagram %>" target="_blank" rel="noopener noreferrer" title="Instagram"><i class="bi bi-instagram"></i></a>
            <% } %>
            <% if (ss.social_whatsapp) { %>
                <a href="<%= ss.social_whatsapp %>" target="_blank" rel="noopener noreferrer" title="WhatsApp"><i class="bi bi-whatsapp"></i></a>
            <% } %>
        </div>

    </div>
</header>