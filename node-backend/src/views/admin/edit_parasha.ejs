        <h5>Admin Panel</h5>
    </div>
    <a href="/" target="_blank"><i class="bi bi-globe"></i> Ver mi Web</a>
    <a href="/admin/dashboard" class="active"><i class="bi bi-speedometer2"></i> Dashboard</a>
    <div class="nav-label">Contenido</div>
    <a href="/admin/dynamic-sections"><i class="bi bi-puzzle"></i> Mis Secciones</a>
    <a href="/admin/sections"><i class="bi bi-layout-text-window-reverse"></i> Secciones Home</a>
    <% if (role === 'admin') { %>
        <div class="nav-label">Administración</div>
        <a href="/admin/settings"><i class="bi bi-gear"></i> Configuración</a>
