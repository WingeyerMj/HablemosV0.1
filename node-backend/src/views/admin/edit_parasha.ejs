<main class="col-md-10 main-content">
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-pencil-square me-2" style="color: var(--primary-color);"></i>Editar Parasha</h1>
            <p class="text-white-50 mb-0">Editando: <strong><%= parasha.title %></strong></p>
        </div>
        <a href="/admin/dashboard#pills-services" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>

    <form action="/admin/parashot/update" method="POST" enctype="multipart/form-data" id="editParashaForm">
        <input type="hidden" name="id" value="<%= parasha.id %>">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label small text-white-50">Nº</label>
                <input type="number" name="parasha_number" class="form-control" value="<%= parasha.parasha_number || '' %>" min="1">
            </div>
            <div class="col-md-4">
                <label class="form-label small text-white-50">Título</label>
                <input type="text" name="title" class="form-control" required value="<%= parasha.title %>">
            </div>
            <div class="col-md-6">
                <label class="form-label small text-white-50">Subtítulo / Versículo</label>
                <input type="text" name="subtitle" class="form-control" value="<%= parasha.subtitle || '' %>">
            </div>

            <div class="col-md-12">
                <label class="form-label small text-white-50">Resumen Breve</label>
                <input type="text" name="description" class="form-control" value="<%= parasha.description || '' %>">
            </div>

            <div class="col-md-6">
                <label class="form-label small text-white-50">Link de YouTube</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-youtube"></i></span>
                    <input type="text" name="youtube_link" class="form-control" value="<%= parasha.youtube_link || '' %>">
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label small text-white-50">Subir PDF (descargable)</label>
                <input type="file" name="pdf_upload" class="form-control" accept=".pdf">
                <% if (parasha.pdf_file) { %>
                    <small class="text-success mt-1 d-block"><i class="bi bi-file-pdf me-1"></i>PDF actual: <a href="<%= parasha.pdf_file %>" target="_blank" class="text-success"><%= parasha.pdf_file %></a></small>
                    <input type="hidden" name="pdf_file" value="<%= parasha.pdf_file %>">
                <% } %>
            </div>

            <div class="col-md-4">
                <label class="form-label small text-white-50">Subir Imagen</label>
                <input type="file" name="image_file" id="edit_image_file" class="form-control" accept="image/*">
            </div>
            <div class="col-md-4">
                <label class="form-label small text-white-50">O URL de Imagen</label>
                <input type="text" name="image_url" id="edit_image_url" class="form-control" value="<%= parasha.image_url || '' %>">
            </div>
            <div class="col-md-4 text-center">
                <div class="border border-secondary rounded overflow-hidden" style="height:120px;background:rgba(0,0,0,0.2);display:flex;align-items:center;justify-content:center;">
                    <img id="editImgPreview" src="<%= parasha.image_url || '/assets/img/blog/blog-1.jpg' %>" style="max-width:100%;max-height:100%;object-fit:contain;">
                </div>
            </div>

            <div class="col-12">
                <label class="form-label small text-white-50">Contenido Completo (Enseñanza)</label>
                <div id="edit-parasha-editor" style="height:400px;background:white;color:black;border-radius:5px;"></div>
                <input type="hidden" name="content" id="editParashaContent">
            </div>
        </div>

        <div class="d-flex justify-content-end mt-4 mb-5 gap-3">
            <a href="/admin/dashboard#pills-services" class="btn btn-outline-secondary px-4">Cancelar</a>
            <button type="submit" class="btn btn-primary px-5"><i class="bi bi-check-lg me-2"></i>Guardar Cambios</button>
        </div>
    </form>
</main>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const quill = new Quill('#edit-parasha-editor', {
        theme: 'snow',
        modules: { toolbar: [[{'header':[1,2,3,false]}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],['link','blockquote','code-block','image'],[{'list':'ordered'},{'list':'bullet'}],[{'align':[]}],['clean']] }
    });
    quill.root.innerHTML = `<%- (parasha.content || parasha.description || '').replace(/`/g, '\\`').replace(/\\/g, '\\\\') %>`;
    
    // Image previews
    const urlInput = document.getElementById('edit_image_url');
    const fileInput = document.getElementById('edit_image_file');
    const previewImg = document.getElementById('editImgPreview');

    if (urlInput) {
        urlInput.addEventListener('input', e => {
            if (e.target.value) previewImg.src = e.target.value;
        });
    }

    if (fileInput) {
        fileInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = e => {
                    previewImg.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    }

    document.getElementById('editParashaForm').onsubmit = function() {
        document.getElementById('editParashaContent').value = quill.root.innerHTML;
        return true;
    };
});
</script>
