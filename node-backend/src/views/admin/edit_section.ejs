<nav class="col-md-2 d-md-block sidebar">
    <div class="text-center mb-4">
        <img src="/assets/img/pagina/logo.svg" alt="Logo" class="img-fluid"
            style="max-height: 60px; border-radius: 50%;">
        <h5 class="mt-2 fw-bold" style="color: var(--primary-color);">Admin Panel</h5>
    </div>
    <hr style="border-color: rgba(255,255,255,0.1);">

    <a href="/" target="_blank">
        <i class="bi bi-globe"></i> Ver mi Web
    </a>

    <a href="/admin/dynamic-sections">
        <i class="bi bi-puzzle"></i> Mis Secciones
    </a>

    <div class="mt-auto">
        <hr style="border-color: rgba(255,255,255,0.1);">
        <a href="/admin/logout" class="text-danger">
            <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
        </a>
    </div>
</nav>

<main class="col-md-10 p-4">
    <div
        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Editando: <%= section.section_name %>
        </h1>
    </div>

    <form action="/admin/edit" method="POST" class="card p-4 shadow-sm">
        <input type="hidden" name="id" value="<%= section.id %>">

        <div class="mb-3">
            <label class="form-label">Título de la Sección</label>
            <input type="text" name="title" class="form-control" value="<%= section.title %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Subtítulo / Descripción Corta</label>
            <textarea name="subtitle" class="form-control" rows="2"><%= section.subtitle %></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Contenido Principal</label>
            <textarea name="content" class="form-control" rows="10"><%= section.content %></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">URL de Imagen (Opcional)</label>
            <input type="text" name="image_url" class="form-control" value="<%= section.image_url %>">
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success px-5">Guardar Cambios</button>
            <a href="/admin/dynamic-sections" class="btn btn-secondary ms-2">Cancelar</a>
        </div>
    </form>
</main>