<%- include('partials/_sidebar') %>

<main class="col-md-10 p-4">
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
        <div>
            <h1 class="h2"><i class="bi bi-puzzle"></i> Mis Secciones</h1>
            <p class="text-white-50 small">Gestioná todas las secciones y páginas de tu sitio web desde un solo lugar.
            </p>
        </div>
        <% if (role==='admin' ) { %>
            <a href="/admin/dynamic-sections/new" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> Crear Nueva Página/Sección
            </a>
            <% } %>
    </div>

    <!-- TABS PARA CATEGORIZAR -->
    <ul class="nav nav-tabs mb-4 border-secondary" id="sectionsTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active text-white border-secondary" id="dynamic-tab" data-bs-toggle="tab"
                data-bs-target="#dynamic" type="button" role="tab">🧩 Secciones</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-white border-secondary" id="content-tab" data-bs-toggle="tab"
                data-bs-target="#content" type="button" role="tab">📦 Contenido Especial</button>
        </li>
    </ul>

    <div class="tab-content" id="sectionsTabContent">
        <!-- SECCIONES DINÁMICAS -->
        <div class="tab-pane fade show active" id="dynamic" role="tabpanel">
            <div class="row g-4">
                <% if (typeof dynamicSections !=='undefined' && dynamicSections.length> 0) { %>
                    <% dynamicSections.forEach(ds=> { %>
                        <div class="col-md-4">
                            <div
                                class="card bg-dark text-white border-secondary h-100 shadow-sm <%= !ds.is_active ? 'opacity-50' : '' %>">
                                <div
                                    class="card-header border-secondary d-flex justify-content-between align-items-center">
                                    <span
                                        class="badge <%= ds.section_type === 'inline' ? 'bg-primary' : 'bg-warning text-dark' %>">
                                        <%= ds.section_type==='inline' ? 'Inline' : 'Página' %>
                                    </span>
                                    <div class="form-check form-switch m-0">
                                        <a href="/admin/dynamic-sections/toggle/<%= ds.id %>"
                                            class="text-decoration-none">
                                            <input class="form-check-input" type="checkbox" <%=ds.is_active ? 'checked'
                                                : '' %> style="cursor: pointer;">
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title text-truncate"><i class="bi <%= ds.icon %> text-primary"></i>
                                        <%= ds.title %>
                                    </h5>
                                    <p class="card-text small text-white-50 text-truncate-2">
                                        <%= ds.summary || 'Sin resumen definido.' %>
                                    </p>
                                    <div class="d-flex gap-2 mt-3">
                                        <a href="/admin/dynamic-sections/edit/<%= ds.id %>"
                                            class="btn btn-sm btn-outline-primary flex-grow-1">
                                            <i class="bi bi-pencil"></i> Editar
                                        </a>
                                        <% if (role==='admin' && !['hero', 'about' , 'calendario' ].includes(ds.slug)) {
                                            %>
                                            <a href="/admin/dynamic-sections/delete/<%= ds.id %>"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('¿Eliminar esta sección?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                            <% } %>
                                    </div>
                                    <% if (ds.data_table) { %>
                                        <div class="mt-2">
                                            <a href="/admin/entity/<%= ds.data_table %>"
                                                class="btn btn-sm btn-success w-100">
                                                <i class="bi bi-table"></i> Gestionar Datos
                                            </a>
                                        </div>
                                        <% } %>
                                </div>
                                <div
                                    class="card-footer border-secondary p-2 bg-black bg-opacity-25 d-flex justify-content-between small">
                                    <span class="text-white-50"><i class="bi bi-sort-numeric-down"></i> Orden: <%=
                                            ds.nav_order %></span>
                                    <% if (ds.show_in_navbar) { %>
                                        <span class="text-success"><i class="bi bi-list"></i> En menú</span>
                                        <% } %>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="col-12 text-center py-5">
                                    <i class="bi bi-puzzle text-white-50" style="font-size: 3rem;"></i>
                                    <p class="mt-3 text-white-50">No hay secciones creadas.</p>
                                </div>
                                <% } %>
            </div>
        </div>

        <!-- CONTENIDO ESPECIAL (PARASHOT, TEAM, ETC) -->
        <div class="tab-pane fade" id="content" role="tabpanel">
            <div class="alert alert-info bg-transparent border-info text-white-50">
                <i class="bi bi-info-circle me-2"></i> Estas secciones contienen listas de datos específicos (tablas)
                que se muestran en el Dashboard principal.
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card bg-dark text-white border-secondary">
                        <div class="card-body text-center py-4">
                            <i class="bi bi-book text-success display-6 mb-3"></i>
                            <h5>Parashot</h5>
                            <p class="small text-white-50">Estudios semanales de la Torá.</p>
                            <a href="/admin/dashboard#services" class="btn btn-sm btn-success">Gestionar Tabla</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark text-white border-secondary">
                        <div class="card-body text-center py-4">
                            <i class="bi bi-people text-warning display-6 mb-3"></i>
                            <h5>Equipo</h5>
                            <p class="small text-white-50">Miembros de la congregación.</p>
                            <a href="/admin/dashboard#team" class="btn btn-sm btn-warning text-dark">Gestionar Tabla</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark text-white border-secondary">
                        <div class="card-body text-center py-4">
                            <i class="bi bi-calendar-event text-info display-6 mb-3"></i>
                            <h5>Eventos (Portfolio)</h5>
                            <p class="small text-white-50">Galería de actividades pasadas.</p>
                            <a href="/admin/dashboard#portfolio" class="btn btn-sm btn-info">Gestionar Tabla</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark text-white border-secondary">
                        <div class="card-body text-center py-4">
                            <i class="bi bi-star text-primary display-6 mb-3"></i>
                            <h5>Testimonios</h5>
                            <p class="small text-white-50">Comentarios de los hermanos.</p>
                            <a href="/admin/dashboard#testimonials" class="btn btn-sm btn-primary">Gestionar Tabla</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>