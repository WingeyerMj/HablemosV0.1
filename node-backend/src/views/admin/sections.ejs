<%- include('partials/_sidebar') %>

<!-- Main Content -->
<main class="col-md-10 main-content">
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-layout-text-window-reverse me-2" style="color: var(--primary-color);"></i>Secciones del Home</h1>
            <p class="text-white-50 mb-0">Edita los títulos, subtítulos y contenido de las secciones principales del sitio.</p>
        </div>
    </div>

    <% if (sections && sections.length > 0) { %>
        <div class="row g-4">
            <% sections.forEach((section, idx) => { %>
                <div class="col-md-6">
                    <div class="card bg-dark border-secondary">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background: rgba(212,184,149,0.05); border-bottom: 1px solid rgba(255,255,255,0.06);">
                            <h5 class="mb-0" style="color: var(--primary-color);">
                                <i class="bi bi-bookmark-fill me-2"></i><%= section.section_name %>
                            </h5>
                            <span class="badge bg-secondary"><%= section.page %></span>
                        </div>
                        <div class="card-body">
                            <form action="/admin/sections/update" method="POST" enctype="multipart/form-data">
                                <input type="hidden" name="id" value="<%= section.id %>">
                                <input type="hidden" name="tableName" value="<%= section.tableName %>">
                                
                                <div class="mb-3">
                                    <label class="form-label small text-white-50">Título</label>
                                    <input type="text" name="title" class="form-control" value="<%= section.title || '' %>" placeholder="Título de la sección">
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label small text-white-50">Subtítulo</label>
                                    <input type="text" name="subtitle" class="form-control" value="<%= section.subtitle || '' %>" placeholder="Subtítulo o eslogan">
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label small text-white-50">Contenido</label>
                                    <textarea name="content" class="form-control" rows="4" placeholder="Contenido de la sección..."><%= section.content || '' %></textarea>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small text-white-50">URL de Imagen</label>
                                    <div class="input-group">
                                        <input type="text" name="image_url" class="form-control" value="<%= section.image_url || '' %>" placeholder="/assets/img/...">
                                        <span class="input-group-text bg-dark border-secondary text-white-50">
                                            <i class="bi bi-image"></i>
                                        </span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label small text-white-50">O subir imagen</label>
                                    <input type="file" name="image_file" class="form-control">
                                </div>

                                <% if (section.image_url) { %>
                                    <div class="mb-3 text-center">
                                        <img src="<%= section.image_url %>" alt="Preview" class="img-fluid rounded" style="max-height: 120px; opacity: 0.7;">
                                    </div>
                                <% } %>

                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-white-50">
                                        <i class="bi bi-clock me-1"></i>
                                        Actualizado: <%= section.updated_at ? new Date(section.updated_at).toLocaleDateString('es-ES') : 'Nunca' %>
                                    </small>
                                    <button type="submit" class="btn btn-primary btn-sm px-4">
                                        <i class="bi bi-check-lg me-1"></i> Guardar
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="bi bi-inbox text-white-50" style="font-size: 4rem;"></i>
            <p class="text-white-50 mt-3">No hay secciones creadas todavía. Se crearán automáticamente al ejecutar el schema SQL.</p>
        </div>
    <% } %>
</main>
