<%- include('partials/_sidebar') %>

<main class="col-md-10 main-content">
    <div class="page-header">
        <h1>Panel de Control</h1>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card-stat d-flex align-items-center gap-3"><div class="stat-icon"><i class="bi bi-journal-text"></i></div><div><div class="text-white-50 small">Parashot</div><div class="fs-4 fw-bold"><%= parashot.length %></div></div></div></div>
        <div class="col-md-3"><div class="card-stat d-flex align-items-center gap-3"><div class="stat-icon"><i class="bi bi-calendar-event"></i></div><div><div class="text-white-50 small">Eventos</div><div class="fs-4 fw-bold"><%= portfolio.length %></div></div></div></div>
        <div class="col-md-3"><div class="card-stat d-flex align-items-center gap-3"><div class="stat-icon"><i class="bi bi-people"></i></div><div><div class="text-white-50 small">Equipo</div><div class="fs-4 fw-bold"><%= team.length %></div></div></div></div>
        <div class="col-md-3"><div class="card-stat d-flex align-items-center gap-3"><div class="stat-icon"><i class="bi bi-star"></i></div><div><div class="text-white-50 small">Testimonios</div><div class="fs-4 fw-bold"><%= testimonials.length %></div></div></div></div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-pills mb-4" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation"><button class="nav-link active" id="pills-services-tab" data-bs-toggle="pill" data-bs-target="#pills-services" type="button">📖 Parashot</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="pills-portfolio-tab" data-bs-toggle="pill" data-bs-target="#pills-portfolio" type="button">🗓️ Eventos</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="pills-team-tab" data-bs-toggle="pill" data-bs-target="#pills-team" type="button">👥 Equipo</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="pills-testimonials-tab" data-bs-toggle="pill" data-bs-target="#pills-testimonials" type="button">⭐ Testimonios</button></li>
    </ul>

    <div class="tab-content" id="pills-tabContent">

        <!-- PARASHOT TAB -->
        <div class="tab-pane fade show active" id="pills-services" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Gestión de Parashot</h4>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createParashaModal"><i class="bi bi-plus-circle"></i> Nueva Parasha</button>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead><tr><th>Nº</th><th>Título</th><th>Descripción</th><th>PDF</th><th>Acciones</th></tr></thead>
                    <tbody>
                        <% parashot.forEach(p => { %>
                        <tr>
                            <td><%= p.parasha_number || '-' %></td>
                            <td><%= p.title %></td>
                            <td><span class="text-truncate d-inline-block" style="max-width:200px;"><%= p.description %></span></td>
                            <td><% if (p.pdf_file) { %><a href="<%= p.pdf_file %>" target="_blank" class="badge bg-success"><i class="bi bi-file-pdf"></i> PDF</a><% } else { %>-<% } %></td>
                            <td>
                                <a href="/admin/parashot/edit/<%= p.id %>" class="btn btn-sm btn-primary me-1">Editar</a>
                                <a href="/admin/parashot/delete/<%= p.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar esta Parashá?')">Eliminar</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- EVENTOS TAB -->
        <div class="tab-pane fade" id="pills-portfolio" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Gestión de Eventos</h4>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createPortfolioModal"><i class="bi bi-plus-circle"></i> Nuevo Evento</button>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead><tr><th>Título</th><th>Categoría</th><th>Fecha</th><th>Acciones</th></tr></thead>
                    <tbody>
                        <% portfolio.forEach(item => { %>
                        <tr>
                            <td><%= item.title %></td>
                            <td><%= item.category %></td>
                            <td><%= item.event_date ? new Date(item.event_date).toLocaleDateString('es-ES') : '-' %></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-primary me-1 edit-portfolio-btn"
                                    data-id="<%= item.id %>" data-title="<%= item.title %>" data-category="<%= item.category %>"
                                    data-date="<%= item.event_date ? new Date(item.event_date).toISOString().split('T')[0] : '' %>"
                                    data-subtitle="<%= item.subtitle || '' %>" data-description="<%= item.description || '' %>"
                                    data-image="<%= item.image_url || item.img %>"
                                    data-content='<%= item.content ? item.content.replace(/'/g, "&#39;") : "" %>'>Editar</button>
                                <a href="/admin/portfolio/delete/<%= item.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este Evento?')">Eliminar</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- EQUIPO TAB -->
        <div class="tab-pane fade" id="pills-team" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Gestión de Equipo</h4>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createTeamModal"><i class="bi bi-plus-circle"></i> Nuevo Miembro</button>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead><tr><th>Nombre</th><th>Rol</th><th>Acciones</th></tr></thead>
                    <tbody>
                        <% team.forEach(member => { %>
                        <tr>
                            <td><%= member.name %></td><td><%= member.role %></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-primary me-1 edit-team-btn"
                                    data-id="<%= member.id %>" data-name="<%= member.name %>" data-role="<%= member.role %>"
                                    data-description="<%= member.description || '' %>" data-img="<%= member.img || '' %>">Editar</button>
                                <a href="/admin/team/delete/<%= member.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este miembro?')">Eliminar</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TESTIMONIOS TAB -->
        <div class="tab-pane fade" id="pills-testimonials" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Gestión de Testimonios</h4>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createTestimonialModal"><i class="bi bi-plus-circle"></i> Nuevo Testimonio</button>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead><tr><th>Nombre</th><th>Rol</th><th>Testimonio</th><th>Acciones</th></tr></thead>
                    <tbody>
                        <% testimonials.forEach(t => { %>
                        <tr>
                            <td><%= t.name %></td><td><%= t.role %></td>
                            <td><span class="text-truncate d-inline-block" style="max-width:250px;"><%= t.text %></span></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-primary me-1 edit-testimonial-btn"
                                    data-id="<%= t.id %>" data-name="<%= t.name %>" data-role="<%= t.role %>"
                                    data-text="<%= t.text %>" data-img="<%= t.img || '' %>">Editar</button>
                                <a href="/admin/testimonials/delete/<%= t.id %>" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este testimonio?')">Eliminar</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<%- include('_modals') %>