<!-- MODAL: NUEVA PARASHA -->
<div class="modal fade" id="createParashaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Añadir Nueva Parasha</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/admin/parashot/create" method="POST" enctype="multipart/form-data" id="createParashaForm">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label small text-white-50">Nº</label>
                            <input type="number" name="parasha_number" class="form-control" placeholder="#" min="1">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-white-50">Título</label>
                            <input type="text" name="title" class="form-control" required placeholder="Ej: Bereshit">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-white-50">Subtítulo / Versículo</label>
                            <input type="text" name="subtitle" class="form-control" placeholder="Ej: Génesis 1:1">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small text-white-50">Resumen Breve</label>
                            <input type="text" name="description" class="form-control" placeholder="Introducción corta...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-white-50">Link de YouTube</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-youtube"></i></span>
                                <input type="text" name="youtube_link" class="form-control" placeholder="https://www.youtube.com/watch?v=...">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-white-50">Subir PDF (descargable)</label>
                            <input type="file" name="pdf_upload" class="form-control" accept=".pdf">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-white-50">Subir Imagen</label>
                            <input type="file" id="create_image_file" name="image_file" class="form-control" accept="image/*">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-white-50">O URL de Imagen</label>
                            <input type="text" id="create_image_url" name="image_url" class="form-control" placeholder="https://...">
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="border border-secondary rounded overflow-hidden d-flex align-items-center justify-content-center" style="height:100px;background:rgba(0,0,0,0.2);">
                                <img id="createImgPreview" src="/assets/img/blog/blog-1.jpg" style="max-width:100%;max-height:100%;object-fit:contain;">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-white-50">Contenido Completo (Enseñanza)</label>
                            <div id="create-editor-container" style="height:300px;background:white;color:black;border-radius:5px;"></div>
                            <input type="hidden" name="content" id="createContentInput">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success px-4">Crear Parasha</button>
                </div>
            </form>
        </div>
    </div>
</div>

