<!-- Quill Editor -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const qCfg = { theme:'snow', modules:{ toolbar:[[{'header':[1,2,3,false]}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],['link','blockquote','code-block','image'],[{'list':'ordered'},{'list':'bullet'}],[{'align':[]}],['clean']] }};

    const qCreate = new Quill('#create-editor-container', qCfg);
    const qPort = new Quill('#port-editor-container', qCfg);
    const qEditPort = new Quill('#edit-port-editor-container', qCfg);

    // Image previews
    function setupPreview(urlId, fileId, prevId) {
        const u=document.getElementById(urlId), f=document.getElementById(fileId), p=document.getElementById(prevId);
        if(u) u.addEventListener('input',e=>{if(e.target.value)p.src=e.target.value;});
        if(f) f.addEventListener('change',function(){const file=this.files[0];if(file){const r=new FileReader();r.onload=e=>{p.src=e.target.result;};r.readAsDataURL(file);}});
    }
    setupPreview('create_image_url','create_image_file','createImgPreview');
    setupPreview('port_image_url','port_image_file','portImgPreview');
    setupPreview('edit_port_image_url','edit_port_image_file','editPortImgPreview');

    // Edit Portfolio modal
    const editPortModal = new bootstrap.Modal(document.getElementById('editPortfolioModal'));
    document.querySelectorAll('.edit-portfolio-btn').forEach(btn=>{
        btn.onclick=function(){
            const d=this.dataset;
            document.getElementById('edit_port_id').value=d.id;
            document.getElementById('edit_port_title').value=d.title;
            document.getElementById('edit_port_category').value=d.category;
            document.getElementById('edit_port_date').value=d.date;
            document.getElementById('edit_port_subtitle').value=d.subtitle;
            document.getElementById('edit_port_description').value=d.description;
            document.getElementById('edit_port_image_url').value=d.image;
            document.getElementById('editPortImgPreview').src=d.image||'/assets/img/blog/blog-1.jpg';
            qEditPort.root.innerHTML=d.content;
            editPortModal.show();
        };
    });

    // Edit Team modal
    const editTeamModal = new bootstrap.Modal(document.getElementById('editTeamModal'));
    document.querySelectorAll('.edit-team-btn').forEach(btn=>{
        btn.onclick=function(){
            const d=this.dataset;
            document.getElementById('edit_team_id').value=d.id;
            document.getElementById('edit_team_name').value=d.name;
            document.getElementById('edit_team_role').value=d.role;
            document.getElementById('edit_team_description').value=d.description;
            document.getElementById('edit_team_image_url').value=d.img;
            editTeamModal.show();
        };
    });

    // Edit Testimonial modal
    const editTestModal = new bootstrap.Modal(document.getElementById('editTestimonialModal'));
    document.querySelectorAll('.edit-testimonial-btn').forEach(btn=>{
        btn.onclick=function(){
            const d=this.dataset;
            document.getElementById('edit_test_id').value=d.id;
            document.getElementById('edit_test_name').value=d.name;
            document.getElementById('edit_test_role').value=d.role;
            document.getElementById('edit_test_img').value=d.img;
            document.getElementById('edit_test_text').value=d.text;
            editTestModal.show();
        };
    });

    // Form submissions with Quill content
    document.getElementById('createParashaForm').onsubmit=function(){document.getElementById('createContentInput').value=qCreate.root.innerHTML;return true;};
    document.getElementById('createPortfolioForm').onsubmit=function(){document.getElementById('portContentInput').value=qPort.root.innerHTML;return true;};
    document.getElementById('editPortfolioForm').onsubmit=function(){document.getElementById('editPortContentInput').value=qEditPort.root.innerHTML;return true;};

    // Tab hash management
    function activateTab(){const h=window.location.hash;if(h){const t=document.querySelector(`.nav-pills button[data-bs-target="${h}"]`);if(t)bootstrap.Tab.getOrCreateInstance(t).show();}}
    activateTab();
    window.addEventListener('hashchange',activateTab);
    document.querySelectorAll('.nav-pills button').forEach(b=>{b.addEventListener('shown.bs.tab',e=>{const h=e.target.getAttribute('data-bs-target');if(window.location.hash!==h)history.replaceState(null,null,h);});});
});
</script>
