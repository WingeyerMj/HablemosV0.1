<!-- Sidebar -->
<nav class="col-md-2 d-md-block sidebar">
    <div class="brand">
        <img src="/assets/img/pagina/logo.svg" alt="Logo" class="img-fluid">
        <h5>Admin Panel</h5>
    </div>

    <a href="/" target="_blank"><i class="bi bi-globe"></i> Ver mi Web</a>
    <a href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>

    <div class="nav-label">Contenido</div>
    <a href="/admin/dynamic-sections"><i class="bi bi-puzzle"></i> Mis Secciones</a>
    <a href="/admin/sections"><i class="bi bi-layout-text-window-reverse"></i> Secciones Home</a>

    <% if (role === 'admin') { %>
        <div class="nav-label">Administración</div>
        <a href="/admin/settings" class="active"><i class="bi bi-gear"></i> Configuración</a>
        <a href="/admin/users"><i class="bi bi-people"></i> Usuarios</a>
    <% } %>

    <div class="mt-auto">
        <hr style="border-color: rgba(255,255,255,0.1);">
        <a href="/admin/logout" class="text-danger"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a>
        <div class="mt-3 small text-white-50 p-2">
            <i class="bi bi-person-circle"></i> <%= username %><br>
            <span class="badge bg-secondary mt-1"><%= role %></span>
        </div>
    </div>
</nav>

<!-- Main Content -->
<main class="col-md-10 main-content">
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-gear me-2" style="color: var(--primary-color);"></i>Configuración del Sitio</h1>
            <p class="text-white-50 mb-0">Edita la información de contacto, redes sociales y configuración general.</p>
        </div>
    </div>

    <form action="/admin/settings/update" method="POST">
        <% 
            const groupLabels = {
                'general': { icon: 'bi-globe', title: 'General' },
                'contact': { icon: 'bi-telephone', title: 'Información de Contacto' },
                'social': { icon: 'bi-share', title: 'Redes Sociales' }
            };
        %>

        <% Object.keys(settingsGrouped).forEach(group => { %>
            <div class="card bg-dark border-secondary mb-4">
                <div class="card-header" style="background: rgba(212,184,149,0.05); border-bottom: 1px solid rgba(255,255,255,0.06);">
                    <h5 class="mb-0" style="color: var(--primary-color);">
                        <i class="bi <%= groupLabels[group] ? groupLabels[group].icon : 'bi-sliders' %> me-2"></i>
                        <%= groupLabels[group] ? groupLabels[group].title : group.charAt(0).toUpperCase() + group.slice(1) %>
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <% settingsGrouped[group].forEach(setting => { %>
                            <div class="col-md-6">
                                <label class="form-label small text-white-50">
                                    <%= setting.label || setting.setting_key %>
                                </label>
                                <% if (setting.setting_type === 'textarea') { %>
                                    <textarea name="<%= setting.setting_key %>" class="form-control" rows="3"><%= setting.setting_value || '' %></textarea>
                                <% } else { %>
                                    <div class="input-group">
                                        <% if (setting.setting_type === 'email') { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-envelope"></i></span>
                                        <% } else if (setting.setting_type === 'url') { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-link-45deg"></i></span>
                                        <% } else if (setting.setting_key.includes('phone')) { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-telephone"></i></span>
                                        <% } else if (setting.setting_key.includes('youtube')) { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-youtube"></i></span>
                                        <% } else if (setting.setting_key.includes('facebook')) { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-facebook"></i></span>
                                        <% } else if (setting.setting_key.includes('instagram')) { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-instagram"></i></span>
                                        <% } else if (setting.setting_key.includes('whatsapp')) { %>
                                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-whatsapp"></i></span>
                                        <% } %>
                                        <input type="<%= setting.setting_type === 'email' ? 'email' : (setting.setting_type === 'url' ? 'url' : 'text') %>" 
                                               name="<%= setting.setting_key %>" 
                                               class="form-control" 
                                               value="<%= setting.setting_value || '' %>"
                                               placeholder="<%= setting.label || '' %>">
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        <% }) %>

        <div class="text-end mb-5">
            <button type="submit" class="btn btn-primary px-5 py-2">
                <i class="bi bi-check-lg me-2"></i> Guardar Configuración
            </button>
        </div>
    </form>
</main>
