<nav class="col-md-2 d-md-block sidebar">
    <div class="text-center mb-4">
        <img src="/assets/img/pagina/logo.svg" alt="Logo" class="img-fluid"
            style="max-height: 60px; border-radius: 50%;">
        <h5 class="mt-2 fw-bold" style="color: var(--primary-color);">Admin Panel</h5>
    </div>
    <hr style="border-color: rgba(255,255,255,0.1);">

    <a href="/" target="_blank">
        <i class="bi bi-globe"></i> Ver mi Web
    </a>

    <a href="/admin/dynamic-sections">
        <i class="bi bi-puzzle"></i> Mis Secciones
    </a>

    <% if (role==='admin' ) { %>
        <a href="/admin/users" class="active">
            <i class="bi bi-people"></i> Usuarios
        </a>
        <% } %>

            <div class="mt-auto">
                <hr style="border-color: rgba(255,255,255,0.1);">
                <a href="/admin/logout" class="text-danger">
                    <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                </a>
                <div class="mt-3 small text-white-50 p-2">
                    <i class="bi bi-person-circle"></i>
                    <%= username %> <br>
                        <span class="badge bg-secondary mt-1">
                            <%= role %>
                        </span>
                </div>
            </div>
</nav>

<main class="col-md-10 p-4">
    <div
        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Gestión de Usuarios</h1>
    </div>

    <!-- Formulario para Administradores -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Crear Nuevo Usuario</h5>
        </div>
        <div class="card-body">
            <form action="/admin/users/create" method="POST" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="username" class="form-control" placeholder="Usuario" required>
                </div>
                <div class="col-md-3">
                    <input type="password" name="password" class="form-control" placeholder="Contraseña" required>
                </div>
                <div class="col-md-3">
                    <input type="email" name="email" class="form-control" placeholder="Email (opcional)">
                </div>
                <div class="col-md-2">
                    <select name="role" class="form-select">
                        <option value="editor">Editor</option>
                        <option value="admin">Administrador</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary w-100">Crear</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Lista de Usuarios -->
    <div class="table-responsive bg-white shadow-sm p-3 rounded">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u=> { %>
                    <tr>
                        <td><strong>
                                <%= u.username %>
                            </strong></td>
                        <td>
                            <%= u.email || '-' %>
                        </td>
                        <td>
                            <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-info' %>">
                                <%= u.role.toUpperCase() %>
                            </span>
                        </td>
                        <td>
                            <% if (u.username !=='admin' ) { %>
                                <a href="/admin/users/delete/<%= u.id %>" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('¿Eliminar usuario?')">Eliminar</a>
                                <% } %>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>
</main>